# PostgreSQL (used by docker-compose for the db service)
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_DB=taskflow

# JWT signing secret — generate with: openssl rand -base64 48
# The default below works for local dev; replace in production.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Allowed origin for CORS
CORS_ORIGIN=http://localhost:3000

# Run idempotent seed on API startup (test user + sample project/tasks)
RUN_SEED=true

# bcrypt cost (must be >= 12 per assignment)
BCRYPT_COST=12
